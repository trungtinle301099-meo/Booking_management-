# Base API URL for Restful Booker service.
BASE_URL=https://restful-booker.herokuapp.com

# Booking API username.
# Do not put real credentials here. Copy this file to .env and set the actual value locally.
BOOKING_USERNAME=your_username_here

# Booking API password.
# Do not put real credentials here. Copy this file to .env and set the actual value locally.
BOOKING_PASSWORD=your_password_here