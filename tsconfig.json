{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "@playwright/test"],
    "paths": {
      "@/*": ["./src/*"],
      "@api/*": ["./src/api/*"],
      "@config/*": ["./src/config/*"],
      "@data/*": ["./src/data/*"],
      "@fixtures/*": ["./src/fixtures/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@schemas/*": ["./src/schemas/*"],
      "@types/*": ["./src/types/*"]
    },
    "noEmit": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "playwright.config.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "playwright-report",
    "test-results",
    "allure-results",
    "allure-report",
    ".backup-config"
  ]
}
